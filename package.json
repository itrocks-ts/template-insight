{
	"author": {
		"name": "Baptiste Pillot",
		"email": "baptiste@pillot.fr"
	},
	"dependencies": {
		"@itrocks/class-type": "latest",
		"@itrocks/class-view": "latest",
		"@itrocks/property-view": "latest",
		"@itrocks/reflect": "latest",
		"@itrocks/rename": "latest",
		"@itrocks/route": "latest",
		"@itrocks/template": "latest",
		"@itrocks/translate": "latest"
	},
	"description": "Extends @itrocks/template with decorator parsing, reflection, and translation features",
	"devDependencies": {
		"@types/jest": "^30.0",
		"@types/node": "^24.10",
		"jest": "^30.2",
		"ts-jest": "^29.4",
		"typescript": "~5.9"
	},
	"engines": {
		"node": ">=18"
	},
	"exports": {
		"import": "./esm/template-insight.js",
		"require": "./cjs/template-insight.js"
	},
	"files": [
		"LICENSE",
		"README.md",
		"*/*.d.ts",
		"*/*.js"
	],
	"homepage": "it.rocks",
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"testMatch": [
			"**/?(*.)+(spec|test).ts"
		]
	},
	"keywords": [
		"backend",
		"decorate",
		"decorator",
		"display",
		"i18n",
		"internationalization",
		"it.rocks",
		"output",
		"reflect",
		"reflection",
		"route",
		"routing",
		"template",
		"translate",
		"translation"
	],
	"license": "ISC",
	"name": "@itrocks/template-insight",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/itrocks-ts/template-insight.git"
	},
	"scripts": {
		"build": "npm run build:cjs && npm run build:esm",
		"build:cjs": "tsc -p tsconfig.cjs.json",
		"build:esm": "tsc -p tsconfig.esm.json",
		"test": "test/test"
	},
	"types": "./esm/template-insight.d.ts",
	"version": "0.1.2"
}
